<Window x:Class="GameMacroManager.Views.TimingCalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="⏱️ Komut Düzenleyici - Timing Calibration"
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="White"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="⏱️ Komut Düzenleyici" FontSize="28" FontWeight="Bold" Foreground="#2196F3"/>
            <TextBlock Text="Tuş basımlarınızı kaydedin ve timing'lerinizi görün" FontSize="14" Foreground="#B0B0B0" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Input Section -->
        <Border Grid.Row="1" Background="#2A2A2A" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Ad:" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox x:Name="NameTextBox" 
                             Background="#1E1E1E" 
                             Foreground="White" 
                             BorderBrush="#444444"
                             Padding="10"
                             FontSize="14"
                             Text="Yeni Komut"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button x:Name="StartRecordButton" Content="🔴 Kayıt Başlat" Click="StartRecordButton_Click" 
                            Background="#4CAF50" Width="150"/>
                    <Button x:Name="StopRecordButton" Content="⏹️ Durdur" Click="StopRecordButton_Click" 
                            Background="#F44336" Width="150" IsEnabled="False"/>
                    <Button x:Name="ClearButton" Content="🗑️ Temizle" Click="ClearButton_Click" 
                            Background="#FF9800" Width="150"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Key Press List -->
        <Border Grid.Row="2" Background="#2A2A2A" CornerRadius="8" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Tuş Vuruşları" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="KeyPressListBox">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E1E" CornerRadius="5" Padding="12,8" Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="16" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding DisplayText}" FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding TimingText}" FontSize="12" Foreground="#B0B0B0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Statistics -->
                <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="5" Padding="15" Margin="0,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Toplam Tuş" FontSize="12" Foreground="#B0B0B0"/>
                            <TextBlock x:Name="TotalKeysText" Text="0" FontSize="20" FontWeight="Bold" Foreground="#2196F3"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Ort. Basılı Tutma" FontSize="12" Foreground="#B0B0B0"/>
                            <TextBlock x:Name="AvgHoldText" Text="0 ms" FontSize="20" FontWeight="Bold" Foreground="#4CAF50"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Ort. Gecikme" FontSize="12" Foreground="#B0B0B0"/>
                            <TextBlock x:Name="AvgDelayText" Text="0 ms" FontSize="20" FontWeight="Bold" Foreground="#FF9800"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="SaveButton" Content="💾 Kaydet" Click="SaveButton_Click" 
                    Background="#9C27B0" IsEnabled="False"/>
            <Button x:Name="CopyButton" Content="📋 JSON Kopyala" Click="CopyButton_Click" 
                    Background="#00BCD4" IsEnabled="False"/>
            <Button x:Name="CloseButton" Content="❌ Kapat" Click="CloseButton_Click" 
                    Background="#F44336"/>
        </StackPanel>
    </Grid>
</Window>
