<Window x:Class="GameMacroManager.Views.CoordinateCaptureOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Koordinat Yakala"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000" 
        WindowState="Maximized"
        Topmost="True"
        Cursor="Cross"
        ShowInTaskbar="False">
    <Grid>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center" 
                Background="#DD1A1A30" CornerRadius="8" Padding="30,20" BorderBrush="#2196F3" BorderThickness="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🎯 Koordinat Seçim Modu" FontSize="20" FontWeight="Bold" Foreground="#2196F3" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Ekranda tıklamak istediğiniz yere Sol veya Sağ Tıklayın." FontSize="14" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Seçilen nokta otomatik olarak kaydedilecektir." FontSize="12" Foreground="#B0B0B0" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock Text="İptal etmek için [ESC] tuşuna basın." FontSize="12" Foreground="#FF5555" HorizontalAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
