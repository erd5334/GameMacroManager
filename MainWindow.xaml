<Window x:Class="GameMacroManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:GameMacroManager"
        xmlns:vm="clr-namespace:GameMacroManager.ViewModels"
        xmlns:models="clr-namespace:GameMacroManager.Models"
        xmlns:helpers="clr-namespace:GameMacroManager.Helpers"
        mc:Ignorable="d"
        Title="🎮 Game Macro Manager" 
        Height="750" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f1a"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Combo Item Template -->
        <DataTemplate x:Key="ComboItemTemplate" DataType="{x:Type models:Combo}">
            <Border Style="{StaticResource ListItemStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                            Background="{StaticResource PurpleGradient}">
                        <TextBlock Text="⚡" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="White"/>
                        <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="2" Background="#333355" CornerRadius="4" Padding="8,4" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock Text="{Binding Hotkey, StringFormat='[{0}]'}" 
                                   FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentBlueBrush}"/>
                    </Border>

                    <Button Grid.Column="3" 
                            Command="{Binding DataContext.AddToPlaylistCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Width="32" Height="32"
                            ToolTip="Playlist'e Ekle"
                            Foreground="{StaticResource AccentGreenBrush}">
                        <materialDesign:PackIcon Kind="PlaylistPlus" Width="20" Height="20"/>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Key Action Template -->
        <DataTemplate x:Key="KeyActionTemplate" DataType="{x:Type models:KeyAction}">
            <Border Background="#2a2a45" CornerRadius="8" Padding="12,10" Margin="0,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Key Selection -->
                    <Grid Grid.Column="0" Margin="0,0,8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tuş / Fare" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                            <ComboBox Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding Source={x:Static helpers:KeyList.AllKeys}}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      IsEditable="True"
                                      FontWeight="Bold" FontSize="12">
                            </ComboBox>
                        </StackPanel>
                        <Button Grid.Column="1" 
                                VerticalAlignment="Bottom"
                                Margin="4,0,0,0"
                                Padding="0"
                                Width="34" Height="34"
                                Command="{Binding DataContext.CaptureCoordinateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Ekranda tıklanacak yerin koordinatını seç"
                                Foreground="{StaticResource AccentBlueBrush}">
                            <materialDesign:PackIcon Kind="Target" Width="20" Height="20"/>
                        </Button>
                    </Grid>

                    <!-- Action Type -->
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="Aksiyon" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <ComboBox SelectedItem="{Binding ActionType}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  FontSize="12" Padding="4,2">
                            <ComboBox.ItemsSource>
                                <x:Array Type="{x:Type models:KeyActionType}">
                                    <models:KeyActionType>Tap</models:KeyActionType>
                                    <models:KeyActionType>Press</models:KeyActionType>
                                    <models:KeyActionType>Release</models:KeyActionType>
                                </x:Array>
                            </ComboBox.ItemsSource>
                        </ComboBox>
                    </StackPanel>

                    <!-- Delay -->
                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                        <TextBlock Text="Gecikme (ms)" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding DelayAfterMs, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="12" Padding="8,4"/>
                    </StackPanel>

                    <!-- Hold Duration -->
                    <StackPanel Grid.Column="3" Margin="0,0,8,0">
                        <TextBlock Text="Basılı (ms)" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding HoldDurationMs, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontSize="12" Padding="8,4"/>
                    </StackPanel>

                    <!-- Delete Button -->
                    <Button Grid.Column="4" 
                            Command="{Binding DataContext.RemoveKeyActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Foreground="#ff5555" ToolTip="Bu tuşu sil"
                            VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Delete" Width="20" Height="20"/>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <!-- Background Gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0f0f1a" Offset="0"/>
                <GradientStop Color="#1a1a2e" Offset="0.5"/>
                <GradientStop Color="#16213e" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1a1a30" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title & Sidebar Toggle -->
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding ToggleSidebarCommand}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Foreground="White"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            ToolTip="Yan Paneli Göster/Gizle">
                        <materialDesign:PackIcon Kind="Menu" Width="24" Height="24"/>
                    </Button>
                    <TextBlock Text="🎮" FontSize="28" VerticalAlignment="Center"/>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Game Macro Manager" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Oyun makrolarını kolayca yönetin" FontSize="12" 
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Toggle Button -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Timing Calibration Button -->
                    <Button x:Name="TimingCalibrationButton" 
                            Click="TimingCalibrationButton_Click"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#9C27B0"
                            Foreground="White"
                            Padding="12,6"
                            Margin="0,0,16,0"
                            ToolTip="Tuş basma hızınızı ve gecikme sürelerinizi ölçün">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Timer" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="⏱️ Timing Calibration" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    
                    <TextBlock Text="Makrolar:" VerticalAlignment="Center" Margin="0,0,8,0" 
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ToggleButton x:Name="EnableToggle" 
                                  IsChecked="{Binding IsEnabled}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  ToolTip="Makroları Etkinleştir/Devre Dışı Bırak"/>
                    <Border Margin="16,0,0,0" CornerRadius="4" Padding="12,6"
                            Background="{Binding IsEnabled, Converter={x:Null}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#333355"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                        <Setter Property="Background" Value="#2d5a27"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="DEVRE DIŞI"/>
                                    <Setter Property="Foreground" Value="#888888"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                            <Setter Property="Text" Value="AKTİF"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <!-- Games Column -->
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="220"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <!-- Characters Column -->
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="220"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Games Panel -->
            <Border Grid.Column="0" Style="{StaticResource DarkCard}" Margin="0,0,16,0"
                    Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="Gamepad" Width="24" Height="24" 
                                                 Foreground="{StaticResource AccentPurpleBrush}"/>
                        <TextBlock Text="OYUNLAR" FontWeight="Bold" FontSize="14" 
                                   Foreground="White" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Game List -->
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding Games}" 
                             SelectedItem="{Binding SelectedGame}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ListItemStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="6" 
                                                Background="{Binding ThemeColor}" Margin="0,0,10,0">
                                            <TextBlock Text="🎮" FontSize="16" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" 
                                                   FontWeight="Medium" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Selected Game Edit -->
                    <Border Grid.Row="2" Background="#1a1a30" CornerRadius="6" Padding="8" Margin="0,8,0,0"
                            Visibility="{Binding SelectedGame, Converter={StaticResource NullableToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Seçili Oyun:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedGame.Name, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Oyun Adı"
                                     FontSize="13" Margin="0,0,0,8"/>
                            <ComboBox Text="{Binding SelectedGame.ExecutableName, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding DataContext.RunningProcesses, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="Oyun Exe Adı (Seçin veya Yazın)"
                                      IsEditable="True"
                                      FontSize="13"
                                      DropDownOpened="GameProcessComboBox_DropDownOpened"/>
                        </StackPanel>
                    </Border>

                    <!-- Add Button -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Command="{Binding AddGameCommand}" 
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="{StaticResource AccentBlueBrush}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus"/>
                                <TextBlock Text="Ekle" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DeleteGameCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#ff5555">
                            <materialDesign:PackIcon Kind="Delete"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Characters Panel -->
            <Border Grid.Column="1" Style="{StaticResource DarkCard}" Margin="0,0,16,0"
                    Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="Account" Width="24" Height="24" 
                                                 Foreground="{StaticResource AccentBlueBrush}"/>
                        <TextBlock Text="KARAKTERLER" FontWeight="Bold" FontSize="14" 
                                   Foreground="White" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Character List -->
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding SelectedGame.Characters}" 
                             SelectedItem="{Binding SelectedCharacter}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ListItemStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="16" 
                                                Background="{Binding AccentColor}" Margin="0,0,10,0">
                                            <TextBlock Text="👤" FontSize="16" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="Medium" Foreground="White"/>
                                            <TextBlock Text="{Binding Combos.Count, StringFormat='{}{0} combo'}" 
                                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Selected Character Edit -->
                    <Border Grid.Row="2" Background="#1a1a30" CornerRadius="6" Padding="8" Margin="0,8,0,0"
                            Visibility="{Binding SelectedCharacter, Converter={StaticResource NullableToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Seçili Karakter:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedCharacter.Name, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Karakter Adı"
                                     FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <!-- Add Button -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Command="{Binding AddCharacterCommand}" 
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="{StaticResource AccentBlueBrush}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus"/>
                                <TextBlock Text="Ekle" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DeleteCharacterCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#ff5555">
                            <materialDesign:PackIcon Kind="Delete"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Combo Editor Panel -->
            <Border Grid.Column="2" Style="{StaticResource DarkCard}" Margin="0,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Combo List Header -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Lightbulb" Width="24" Height="24" 
                                                     Foreground="{StaticResource AccentGreenBrush}"/>
                            <TextBlock Text="COMBOLAR" FontWeight="Bold" FontSize="14" 
                                       Foreground="White" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Command="{Binding AddComboCommand}" 
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="{StaticResource AccentGreenBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus"/>
                                    <TextBlock Text="Yeni Combo" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Combo List -->
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding SelectedCharacter.Combos}"
                             SelectedItem="{Binding SelectedCombo}"
                             ItemTemplate="{StaticResource ComboItemTemplate}"
                             Background="Transparent"
                             BorderThickness="0"
                             MaxHeight="180"/>

                    <!-- Selected Combo Editor -->
                    <Border Grid.Row="2" Background="#1a1a30" CornerRadius="8" Padding="16" Margin="0,16,0,0"
                            BorderBrush="#7b2cbf" BorderThickness="1.5"
                            Visibility="{Binding SelectedCombo, Converter={StaticResource NullableToVisibilityConverter}, FallbackValue=Collapsed}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Combo Info -->
                                <Grid Margin="0,12,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0" Margin="0,0,8,0"
                                             Text="{Binding SelectedCombo.Name, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Combo Adı"/>

                                    <TextBox Grid.Column="1" Margin="0,0,8,0"
                                             Text="{Binding SelectedCombo.Category, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Kategori"/>

                                    <ComboBox Grid.Column="2"
                                              Text="{Binding SelectedCombo.Hotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding Source={x:Static helpers:KeyList.HotkeyKeys}}"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              IsEditable="True"
                                              materialDesign:HintAssist.Hint="Hotkey"/>
                                </Grid>

                                <!-- Options -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <CheckBox Content="Basılı tutulunca tekrarla" 
                                              IsChecked="{Binding SelectedCombo.RepeatWhileHeld}"
                                              Margin="0,0,24,0"/>
                                    <TextBlock Text="Tekrar gecikmesi:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Text="{Binding SelectedCombo.RepeatDelayMs}" Width="60"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                    <TextBlock Text="ms" VerticalAlignment="Center" Margin="4,0,0,0" 
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <!-- Key Actions Header -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Tuş Aksiyonları" FontWeight="SemiBold" Foreground="White"/>
                                    <Button Grid.Column="1" Command="{Binding AddKeyActionCommand}"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Foreground="{StaticResource AccentBlueBrush}" Padding="8,4">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"/>
                                            <TextBlock Text="Tuş Ekle" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <!-- Key Actions List -->
                                <ItemsControl ItemsSource="{Binding SelectedCombo.Actions}"
                                              ItemTemplate="{StaticResource KeyActionTemplate}"/>

                                <!-- Action Buttons -->
                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Right">
                                    <Button Command="{Binding SaveDataCommand}" Margin="0,0,8,0"
                                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                            Background="{StaticResource AccentGreenBrush}"
                                            Foreground="White">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ContentSave"/>
                                            <TextBlock Text="Kaydet" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding TestComboCommand}" Margin="0,0,8,0"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Foreground="{StaticResource AccentBlueBrush}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Play"/>
                                            <TextBlock Text="Test Et (2sn)" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding DuplicateComboCommand}" Margin="0,0,8,0"
                                            Style="{StaticResource MaterialDesignOutlinedButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ContentCopy"/>
                                            <TextBlock Text="Kopyala" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding DeleteComboCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Foreground="#ff5555">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Delete"/>
                                            <TextBlock Text="Sil" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!-- Playlist Panel -->
            <Border Grid.Column="3" Style="{StaticResource DarkCard}" Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="PlaylistPlay" Width="24" Height="24" 
                                                     Foreground="{StaticResource AccentPurpleBrush}"/>
                            <TextBlock Text="COMBO PLAYLIST" FontWeight="Bold" FontSize="14" 
                                       Foreground="White" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="{Binding PlaylistStatus}" 
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>

                        <!-- Control Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Command="{Binding CreatePlaylistCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource PurpleGradient}"
                                    Padding="12,6" Margin="0,0,4,0"
                                    ToolTip="Yeni playlist oluştur">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"/>
                                    <TextBlock Text="Yeni" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ClearPlaylistCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Padding="8,6" Margin="4,0,0,0"
                                    ToolTip="Playlist'i temizle">
                                <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                            </Button>
                        </StackPanel>

                        <!-- Loop Checkbox -->
                        <CheckBox Content="Sonsuz döngü" 
                                  IsChecked="{Binding CurrentPlaylist.IsLooping}"
                                  Margin="0,8,0,0"
                                  IsEnabled="{Binding CurrentPlaylist, Converter={x:Null}}"/>
                    </StackPanel>

                    <!-- Playlist Items -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CurrentPlaylist.Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemStyle}" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Combo Info -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="{Binding DisplayName}" 
                                                           FontWeight="SemiBold" FontSize="12" 
                                                           Foreground="White" VerticalAlignment="Center"/>

                                                <Button Grid.Column="1" 
                                                        Command="{Binding DataContext.RemoveFromPlaylistCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="24" Height="24" Padding="0"
                                                        ToolTip="Kaldır">
                                                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                                                </Button>
                                            </Grid>

                                            <!-- Delay Setting -->
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="Gecikme:" FontSize="10" 
                                                           Foreground="{StaticResource TextSecondaryBrush}" 
                                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBox Text="{Binding DelayAfterMs, UpdateSourceTrigger=PropertyChanged}" 
                                                         Width="60" FontSize="10"
                                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                         materialDesign:HintAssist.Hint="ms"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Play Controls -->
                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <Button Command="{Binding PlayPlaylistCommand}"
                                Height="40" FontSize="14" FontWeight="Bold">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                    <Setter Property="Background" Value="{StaticResource GreenGradient}"/>
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlaylistPlaying}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Play" Width="20" Height="20"/>
                                <TextBlock Text="OYNAT" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding StopPlaylistCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#d32f2f"
                                Height="36" FontSize="13" Margin="0,8,0,0"
                                IsEnabled="{Binding IsPlaylistPlaying}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Stop" Width="18" Height="18"/>
                                <TextBlock Text="DURDUR" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#1a1a30" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#888888"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondaryBrush}"/>

                    <TextBlock Margin="20,0,0,0" Foreground="{StaticResource AccentPurpleBrush}" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveComboName, Converter={x:Null}}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="▶ Çalışıyor: "/>
                        <Run Text="{Binding ActiveComboName}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding OpenDataFolderCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="{StaticResource TextSecondaryBrush}" Padding="8,4"
                            ToolTip="Veri klasörünü aç">
                        <materialDesign:PackIcon Kind="FolderOpen"/>
                    </Button>
                    <Button Command="{Binding ImportProfileCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="{StaticResource TextSecondaryBrush}" Padding="8,4"
                            ToolTip="Profili İçe Aktar (Import)">
                        <materialDesign:PackIcon Kind="Import"/>
                    </Button>
                    <Button Command="{Binding ExportProfileCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="{StaticResource TextSecondaryBrush}" Padding="8,4"
                            ToolTip="Profili Dışa Aktar (Export)">
                        <materialDesign:PackIcon Kind="Export"/>
                    </Button>
                    <TextBlock Text="F9: Açma/Kapama | F10: Tümünü Durdur | Z: Playlist Başlat/Durdur" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
