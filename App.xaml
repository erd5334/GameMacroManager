<Application x:Class="GameMacroManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:GameMacroManager.Helpers"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Teal" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <helpers:NullableToVisibilityConverter x:Key="NullableToVisibilityConverter"/>
            <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <helpers:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>

            <!-- Custom Colors -->
            <Color x:Key="PrimaryDark">#1a1a2e</Color>
            <Color x:Key="SecondaryDark">#16213e</Color>
            <Color x:Key="AccentPurple">#7b2cbf</Color>
            <Color x:Key="AccentBlue">#00d4ff</Color>
            <Color x:Key="AccentGreen">#00ff88</Color>
            <Color x:Key="TextPrimary">#ffffff</Color>
            <Color x:Key="TextSecondary">#a0a0a0</Color>

            <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
            <SolidColorBrush x:Key="SecondaryDarkBrush" Color="{StaticResource SecondaryDark}"/>
            <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurple}"/>
            <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>
            <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>

            <!-- Gradient Brushes -->
            <LinearGradientBrush x:Key="PurpleGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#7b2cbf" Offset="0"/>
                <GradientStop Color="#e040fb" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="BlueGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#00d4ff" Offset="0"/>
                <GradientStop Color="#0099ff" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="GreenGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#00ff88" Offset="0"/>
                <GradientStop Color="#00cc6a" Offset="1"/>
            </LinearGradientBrush>

            <!-- Card Style -->
            <Style x:Key="DarkCard" TargetType="Border">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#252540" Opacity="0.8"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="#000000"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- List Item Style -->
            <Style x:Key="ListItemStyle" TargetType="Border">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="Margin" Value="0,2"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background">
                            <Setter.Value>
                                <SolidColorBrush Color="#7b2cbf" Opacity="0.2"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Button Style -->
            <Style x:Key="GlowButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="Background" Value="{StaticResource AccentPurpleBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
